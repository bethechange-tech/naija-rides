# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit real credentials.

# Neon (or any Postgres) pooled connection — used by Prisma at runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Direct (non-pooled) connection — used by Prisma Migrate
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST/DATABASE?sslmode=require"

# Local Docker fallback
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/NR_LAGOS_dev?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/NR_LAGOS_dev?schema=public"
