{
  "name": "@repo/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm build:prisma && tsup --clean",
    "check-types": "tsc --noEmit",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "build:prisma": "prisma generate",
    "migrate": "prisma migrate",
    "seed": "pnpm --dir ../.. --filter @repo/api seed",
    "push": "prisma db push"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "dotenv": "^17.4.2",
    "prisma": "^7.7.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.7.0",
    "nanoid": "^5.1.9",
    "pg": "^8.20.0"
  }
}